                                hmLines[4].From=pos+Vector2.new(5,5); hmLines[4].To=pos+Vector2.new(15,15)
                                for _,l in pairs(hmLines) do l.Visible=true end
                                task.wait(0.2)
                                for _,l in pairs(hmLines) do l.Visible=false end
                            end)
                        end
                    end
                    lastHealths[p] = h
                end
            end
        end
    end
end)

