local isVehOpen = false

RunService.RenderStepped:Connect(function()
    if not wmConfig.Enabled then wmFrame.Visible = false return else wmFrame.Visible = true end

    local m = 0
    pcall(function() m = localPlayer.leaderstats.Cash.Value end)
    if startMoney == 0 and m > 0 then startMoney = m end

    fpsCount = fpsCount + 1
    if tick() - lastT >= 1 then realFps = fpsCount; fpsCount = 0; lastT = tick() end

    local active = 0
    for k,v in pairs(wmConfig) do if type(v)=="boolean" and string.find(k, "Show") and v then active=active+1 end end
    
    if wmConfig.AutoPos and not dragging then
        if active > 3 or wmConfig.ShowVehicle then
            wmFrame.Position = UDim2.new(0, (Camera.ViewportSize.X/2)-(wmFrame.Size.X.Offset/2), 0, 20)
        else
