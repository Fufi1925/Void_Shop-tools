local chTab = Window:Tab({Title = "Crosshair", Icon = "crosshair"})

local chConfig = {
    Enabled=false, Color=Color3.new(1,1,1), Thick=2, Len=12, Gap=4, Dyn=false, Spin=false, Speed=100
}

local chLines = {Top=Drawing.new("Line"),Bot=Drawing.new("Line"),Lft=Drawing.new("Line"),Rgt=Drawing.new("Line")}
for _,l in pairs(chLines) do l.Visible=false; l.ZIndex=1000 end
local chRot = 0

RunService.RenderStepped:Connect(function(dt)
    if not chConfig.Enabled then for _,l in pairs(chLines) do l.Visible=false end return end
    
    local pos = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2 + 18)
    local gap = chConfig.Gap

    if chConfig.Dyn then
        pcall(function() gap = gap + (localPlayer.Character.HumanoidRootPart.Velocity.Magnitude / 3) end)
    end

    if chConfig.Spin then chRot = (chRot + (chConfig.Speed*dt)) % 360 else chRot = 0 end
    local rad = math.rad(chRot); local cosA, sinA = math.cos(rad), math.sin(rad)

    local function rotP(ox, oy) return Vector2.new(pos.X+(ox*cosA-oy*sinA), pos.Y+(ox*sinA+oy*cosA)) end

    chLines.Top.From = rotP(0, -gap); chLines.Top.To = rotP(0, -(gap+chConfig.Len))
    chLines.Bot.From = rotP(0, gap); chLines.Bot.To = rotP(0, gap+chConfig.Len)
    chLines.Lft.From = rotP(-gap, 0); chLines.Lft.To = rotP(-(gap+chConfig.Len), 0)
    chLines.Rgt.From = rotP(gap, 0); chLines.Rgt.To = rotP(gap+chConfig.Len, 0)

    for _,l in pairs(chLines) do
        l.Color = chConfig.Color; l.Thickness = chConfig.Thick; l.Visible = true
    end
end)

