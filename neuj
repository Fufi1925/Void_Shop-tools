    local txt = string.format('<font color="%s">INFINITY</font> | ', cHex)
    if wmConfig.ShowFPS then txt = txt .. "FPS: " .. realFps .. " | " end
    if wmConfig.ShowPing then
        local p = 0; pcall(function() p = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue()) end)
        txt = txt .. "Ping: " .. p .. "ms | "
    end
    if wmConfig.ShowHP then
        local hp = 100; pcall(function() hp = math.floor(localPlayer.Character.Humanoid.Health) end)
        txt = txt .. "HP: " .. hp .. " | "
    end
    if wmConfig.ShowTime then txt = txt .. os.date("%H:%M") .. " | " end
    if wmConfig.ShowServer then txt = txt .. "Players: " .. #Players:GetPlayers() .. " | " end
    if wmConfig.ShowCops then
        local c = 0
        pcall(function() for _,pl in pairs(Players:GetPlayers()) do if string.find(string.lower(pl.leaderstats.Job.Value), "police") then c=c+1 end end end)
        txt = txt .. "Cops: " .. c .. " | "
    end
    if wmConfig.ShowProfit and startMoney > 0 then
        local prof = m - startMoney
        local pCol = prof >= 0 and "#22c55e" or "#ef4444"
        txt = txt .. string.format('Profit: <font color="%s">%s</font> | ', pCol, (prof>=0 and "+"..prof or prof))
    end

    wmText.Text = txt:sub(1, -4)
    wmFrame.Size = UDim2.new(0, wmText.TextBounds.X + 20, 0, 22)

    if wmConfig.ShowVehicle then
        local inCar, speed, fuel = false, 0, "100%"
        pcall(function()
            local hum = localPlayer.Character.Humanoid
            local hrp = localPlayer.Character.HumanoidRootPart
            speed = math.floor(hrp.Velocity.Magnitude * 1.09)
            if hum.SeatPart or (speed > 20 and hum:GetState() ~= Enum.HumanoidStateType.Freefall) then inCar = true end
            if hum.SeatPart then
                local car = hum.SeatPart:FindFirstAncestorOfClass("Model")
                if car and car:GetAttribute("Fuel") then fuel = math.floor(car:GetAttribute("Fuel")).."%" end
            end
        end)

        if inCar and not isVehOpen then
            isVehOpen = true; TweenService:Create(vehFrame, TweenInfo.new(0.3), {Size=UDim2.new(1,0,0,22)}):Play()
        elseif not inCar and isVehOpen then
            isVehOpen = false; TweenService:Create(vehFrame, TweenInfo.new(0.3), {Size=UDim2.new(1,0,0,0)}):Play()
        end
        if inCar then vehText.Text = string.format("KM/H: %d | Gas: %s", speed, fuel) end
    end
end)

