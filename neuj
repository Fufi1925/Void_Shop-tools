-- Fake Hitmarker logic (Since EH has custom damage, we track health drops in workspace)
local lastHealths = {}
task.spawn(function()
    while task.wait(0.1) do
        if combatCfg.Hitmarker or combatCfg.HitSound then
            for _,p in pairs(Players:GetPlayers()) do
                if p ~= localPlayer and p.Character and p.Character:FindFirstChild("Humanoid") then
                    local h = p.Character.Humanoid.Health
                    if lastHealths[p] and h < lastHealths[p] and h > 0 then
                        if combatCfg.HitSound then hitSoundObj:Play() end
                        if combatCfg.Hitmarker then
                            task.spawn(function()
                                local pos = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2 + 18)
                                hmLines[1].From=pos+Vector2.new(-5,-5); hmLines[1].To=pos+Vector2.new(-15,-15)
