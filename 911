-- === HILFSFUNKTION (Findet dein Auto) ===
local function getLocalCar()
    local plr = Players.LocalPlayer
    local vehicles = workspace:FindFirstChild("Vehicles")
    if not vehicles then return nil end

    for _, car in ipairs(vehicles:GetChildren()) do
        local owner = car:FindFirstChild("Owner")
        if (owner and owner.Value == plr) or car.Name:find(plr.Name) then
            return car
        end
    end
    return nil
end

-- === 1. BELEUCHTUNG (UNDERGLOW) ===
autoTab:Divider({Text = "Beleuchtung"})

local function applyUnderglow()
    -- Altes aufräumen
    for car, data in pairs(underglowParts) do
        if data.part then data.part:Destroy() end
    end
    underglowParts = {}

    if not underglowEnabled then return end
    local vehicles = workspace:FindFirstChild("Vehicles")
    if not vehicles then return end

    for _, car in ipairs(vehicles:GetChildren()) do
        local isMine = false
        local owner = car:FindFirstChild("Owner")
        if (owner and owner.Value == Players.LocalPlayer) or car.Name:find(Players.LocalPlayer.Name) then isMine = true end

        if underglowAll or isMine then
            local body = car:FindFirstChild("Body") and car.Body:FindFirstChild("Body")
            if body and body:IsA("BasePart") then
                local p = Instance.new("Part")
                p.Size = Vector3.new(4, 0.001, 13)
                p.Anchored = true
                p.CanCollide = false
                p.Transparency = 1
                p.CFrame = body.CFrame * CFrame.new(0, -body.Size.Y - 0.05, 0)
                p.Parent = workspace

                local l = Instance.new("SurfaceLight")
                l.Face = Enum.NormalId.Bottom
                l.Angle = 180
                l.Range = 8
                l.Brightness = 4
                l.Color = underglowColor
                l.Parent = p

                underglowParts[car] = {part = p, body = body, light = l}
            end
        end
    end
end

