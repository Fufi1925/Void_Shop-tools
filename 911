-- Updated das Auto automatisch jede Sekunde (besser für Performance als jeden Frame)
task.spawn(function()
    while task.wait(1) do
        pcall(function()
            local myCar = getLocalCar()
            if not myCar then return end

            -- Farbe & Material anwenden
            if carColorEnabled or carMatEnabled then
                for _, part in ipairs(myCar:GetDescendants()) do
                    if part:IsA("BasePart") and (part.Name:find("Body") or part.Name:find("Chassis") or part.Name:find("Door")) then
                        if carColorEnabled then part.Color = carColor end
                        if carMatEnabled then part.Material = carMaterial end
                    end
                end
            end

            -- Hupe anwenden
            if hornSound ~= "Default" then
                for _, sound in ipairs(myCar:GetDescendants()) do
                    if sound:IsA("Sound") and (sound.Name:find("Horn") or sound.Name:find("Honk")) then
                        sound.SoundId = hornList[hornSound]
                    end
                end
            end

            -- Nummernschild anwenden
            if customPlateEnabled then
                for _, textLabel in ipairs(myCar:GetDescendants()) do
                    if textLabel:IsA("TextLabel") and textLabel.Parent and textLabel.Parent.Name:find("Plate") then
                        textLabel.Text = plateText
                    end
                end
            end

        end)
    end
end)
