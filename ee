-- 14.1 BASE64 ENCODING/DECODING ENGINE (For Config Import/Export via Clipboard)
local Base64Engine = {}
local b64chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'
function Base64Engine.Encode(data)
    return ((data:gsub('.', function(x) 
        local r, b = '', x:byte()
        for i = 8, 1, -1 do r = r .. (b % 2^i - b % 2^(i-1) > 0 and '1' or '0') end
        return r;
    end) .. '0000'):gsub('%d%d%d?%d?%d?%d?', function(x)
        if (#x < 6) then return '' end
        local c = 0
        for i = 1, 6 do c = c + (x:sub(i,i) == '1' and 2^(6-i) or 0) end
        return b64chars:sub(c+1, c+1)
    end) .. ({ '', '==', '=' })[#data % 3 + 1])
end
function Base64Engine.Decode(data)
    data = string.gsub(data, '[^'..b64chars..'=]', '')
    return (data:gsub('.', function(x)
        if (x == '=') then return '' end
        local r, f = '', (b64chars:find(x)-1)
        for i = 6, 1, -1 do r = r .. (f % 2^i - f % 2^(i-1) > 0 and '1' or '0') end
        return r;
    end):gsub('%d%d%d?%d?%d?%d?%d?%d?', function(x)
        if (#x ~= 8) then return '' end
        local c = 0
        for i = 1, 8 do c = c + (x:sub(i,i) == '1' and 2^(8-i) or 0) end
        return string.char(c)
    end))
end

-- 14.2 PROFILE DIRECTORY & BACKUP MANAGEMENT
local ProfilesDir = "INFINITYxEH/Profiles"
local BackupsDir = "INFINITYxEH/Backups"

pcall(function()
    if not isfolder(ProfilesDir) then makefolder(ProfilesDir) end
    if not isfolder(BackupsDir) then makefolder(BackupsDir) end
end)

local function GetAvailableProfiles()
    local profileList = {}
    pcall(function()
        if isfolder(ProfilesDir) then
            local files = listfiles(ProfilesDir)
            for _, file in ipairs(files) do
                if file:match("%.json$") then
                    local name = file:match("([^/%\\]+)%.json$")
                    if name then table.insert(profileList, name) end
                end
            end
        end
    end)
    table.sort(profileList)
    return profileList
end

local function CreateBackup(ProfileName)
    pcall(function()
        local filePath = ProfilesDir .. "/" .. ProfileName .. ".json"
        if isfile(filePath) then
            local content = readfile(filePath)
            local timestamp = os.date("%Y%m%d_%H%M%S")
            local backupPath = BackupsDir .. "/" .. ProfileName .. "_bak_" .. timestamp .. ".json"
            writefile(backupPath, content)
            
            -- Limit backups to keep folder clean (max 5 per profile)
            local allBackups = listfiles(BackupsDir)
            local myBackups = {}
            for _, bFile in ipairs(allBackups) do
                if bFile:match(ProfileName .. "_bak_") then table.insert(myBackups, bFile) end
            end
            if #myBackups > 5 then
                table.sort(myBackups)
                delfile(myBackups[1]) -- Delete oldest
            end
        end
    end)
end

-- 14.3 DEEP TABLE MERGE (Ensures backwards compatibility with older configs)
local function DeepTableMerge(target, source)
    for k, v in pairs(source) do
        if type(v) == "table" and type(target[k]) == "table" then
            DeepTableMerge(target[k], v)
        else
            target[k] = v
        end
    end
    return target
end

local function LoadProfileData(ProfileName)
    local success, result = pcall(function()
        local filePath = ProfilesDir .. "/" .. ProfileName .. ".json"
        if not isfile(filePath) then return false end
        local rawData = readfile(filePath)
        local decodedData = HttpService:JSONDecode(rawData)
        
        -- Safe Merge into MasterConfig
        DeepTableMerge(MasterConfig, decodedData)
        SaveMasterConfig() -- Update global state
        return true
    end)
    return success and result
end

local function SaveProfileData(ProfileName)
    local success = pcall(function()
        local filePath = ProfilesDir .. "/" .. ProfileName .. ".json"
        if isfile(filePath) then CreateBackup(ProfileName) end -- Backup existing before overwrite
        
        local Encoded = HttpService:JSONEncode(MasterConfig)
        writefile(filePath, Encoded)
    end)
    return success
end

