local FreecamConnection
local FreecamPos = Vector3.new()
local FreecamFocus = Vector3.new()
local FreecamPitch = 0
local FreecamYaw = 0
local KeysDown = {W=false, A=false, S=false, D=false, Q=false, E=false, Shift=false}

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.W then KeysDown.W = true end
    if input.KeyCode == Enum.KeyCode.A then KeysDown.A = true end
    if input.KeyCode == Enum.KeyCode.S then KeysDown.S = true end
    if input.KeyCode == Enum.KeyCode.D then KeysDown.D = true end
    if input.KeyCode == Enum.KeyCode.Q then KeysDown.Q = true end
    if input.KeyCode == Enum.KeyCode.E then KeysDown.E = true end
    if input.KeyCode == Enum.KeyCode.LeftShift then KeysDown.Shift = true end
end)

UserInputService.InputEnded:Connect(function(input, gpe)
    if input.KeyCode == Enum.KeyCode.W then KeysDown.W = false end
    if input.KeyCode == Enum.KeyCode.A then KeysDown.A = false end
    if input.KeyCode == Enum.KeyCode.S then KeysDown.S = false end
    if input.KeyCode == Enum.KeyCode.D then KeysDown.D = false end
    if input.KeyCode == Enum.KeyCode.Q then KeysDown.Q = false end
    if input.KeyCode == Enum.KeyCode.E then KeysDown.E = false end
    if input.KeyCode == Enum.KeyCode.LeftShift then KeysDown.Shift = false end
end)

local function ToggleFreecam()
    if CineCfg.EnableFreecam then
        -- Initialize Position
        FreecamPos = Camera.CFrame.Position
        FreecamPitch = select(1, Camera.CFrame:ToEulerAnglesYXZ())
        FreecamYaw = select(2, Camera.CFrame:ToEulerAnglesYXZ())
        
        -- Anchor Player
        pcall(function() LocalPlayer.Character.HumanoidRootPart.Anchored = true end)
        Camera.CameraType = Enum.CameraType.Scriptable

        -- Mouse Look Logic
        UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter

        if not FreecamConnection then
            FreecamConnection = RunService.RenderStepped:Connect(function(dt)
                -- Handle Mouse Movement for Look
                local Delta = UserInputService:GetMouseDelta()
                FreecamYaw = FreecamYaw - math.rad(Delta.X * 0.2)
                FreecamPitch = math.clamp(FreecamPitch - math.rad(Delta.Y * 0.2), -math.pi/2, math.pi/2)

                local RotationCFrame = CFrame.Angles(0, FreecamYaw, 0) * CFrame.Angles(FreecamPitch, 0, 0)

                -- Movement Vector
                local MoveVector = Vector3.new(0, 0, 0)
                if KeysDown.W then MoveVector = MoveVector + Vector3.new(0, 0, -1) end
                if KeysDown.S then MoveVector = MoveVector + Vector3.new(0, 0, 1) end
                if KeysDown.A then MoveVector = MoveVector + Vector3.new(-1, 0, 0) end
                if KeysDown.D then MoveVector = MoveVector + Vector3.new(1, 0, 0) end
                if KeysDown.E then MoveVector = MoveVector + Vector3.new(0, 1, 0) end
                if KeysDown.Q then MoveVector = MoveVector + Vector3.new(0, -1, 0) end

                -- Apply Speed and Lerp for smoothness
                local FinalSpeed = KeysDown.Shift and (CineCfg.FreecamSpeed * 3) or CineCfg.FreecamSpeed
                if MoveVector.Magnitude > 0 then
                    MoveVector = MoveVector.Unit * FinalSpeed
                end

                -- Transform local movement to global space
                local GlobalMove = RotationCFrame:VectorToWorldSpace(MoveVector)
                
                -- Smooth Lerping (Drone feel)
                FreecamPos = FreecamPos:Lerp(FreecamPos + GlobalMove, dt * (1 / CineCfg.FreecamSmoothness))

                Camera.CFrame = CFrame.new(FreecamPos) * RotationCFrame
            end)
        end
    else
        if FreecamConnection then FreecamConnection:Disconnect(); FreecamConnection = nil end
        pcall(function() LocalPlayer.Character.HumanoidRootPart.Anchored = false end)
        Camera.CameraType = Enum.CameraType.Custom
        UserInputService.MouseBehavior = Enum.MouseBehavior.Default
    end
