local function RefreshUnderglow()
    for _, data in pairs(UnderglowCache) do if data.Part then data.Part:Destroy() end end
    UnderglowCache = {}

    if not VehCfg.Underglow then return end
    local VehicleFolder = Workspace:FindFirstChild("Vehicles")
    if not VehicleFolder then return end

    for _, Car in pairs(VehicleFolder:GetChildren()) do
        local IsMine = false
        local Owner = Car:FindFirstChild("Owner")
        if (Owner and Owner.Value == LocalPlayer) or Car.Name:find(LocalPlayer.Name) then IsMine = true end

        if VehCfg.UnderglowAll or IsMine then
            local Body = Car:FindFirstChild("Body") and Car.Body:FindFirstChild("Body")
            if Body then
                local GlowPart = Instance.new("Part", Workspace)
                GlowPart.Size = Vector3.new(4, 0.1, 13)
                GlowPart.Anchored = true
                GlowPart.CanCollide = false
                GlowPart.Transparency = 1
                
                local Light = Instance.new("SurfaceLight", GlowPart)
                Light.Face = Enum.NormalId.Bottom
                Light.Brightness = VehCfg.UGBrightness
                Light.Range = 10
                Light.Angle = 180
                Light.Color = Color3.fromRGB(VehCfg.UGColorR, VehCfg.UGColorG, VehCfg.UGColorB)
                
                UnderglowCache[Car] = {Part = GlowPart, Body = Body, Light = Light}
            end
        end
    end
end

