    elseif WMConfig.Style == "Pill" then
        MainCorner.CornerRadius = UDim.new(1, 0)
        MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
        MainFrame.BackgroundTransparency = 0.2
    elseif WMConfig.Style == "Neon" then
        MainFrame.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
        MainFrame.BackgroundTransparency = 0.1
        MainStroke.Enabled = true
        MainStroke.Color = CurrentAccent
        MainStroke.Thickness = 2
    elseif WMConfig.Style == "Minimalist" then
        MainFrame.BackgroundTransparency = 1
        MainText.TextStrokeTransparency = 0.5
    end
end

-- Main Render Loop
local FPSCounter, RealFPS, LastFPSUpdate = 0, 0, tick()
local IsStartupAnimation = true
local IsVehicleMenuOpen = false

RunService.RenderStepped:Connect(function()
    if not WMConfig.Enabled then 
        MainFrame.Visible = false 
        return 
    end

    if not InitialMoneyCaptured and GetCurrentMoney() > 0 then
        InitialMoney = GetCurrentMoney()
        InitialMoneyCaptured = true
    end

    FPSCounter = FPSCounter + 1
    if tick() - LastFPSUpdate >= 1 then
        RealFPS = FPSCounter
        FPSCounter = 0
        LastFPSUpdate = tick()
    end

    if WMConfig.HideInScope then
        local IsScoped = false
        pcall(function()
            local PGui = LocalPlayer:FindFirstChild("PlayerGui")
            if PGui then
                for _, element in pairs(PGui:GetChildren()) do
                    if element:FindFirstChild("5") and element:GetChildren()[1]:FindFirstChild("5").Image == "rbxassetid://285779644" then 
                        IsScoped = true 
                    end
                end
            end
        end)
        if IsScoped then 
            MainFrame.Visible = false 
            return
        elseif not IsStartupAnimation then 
            MainFrame.Visible = true 
        end
    end

    if IsStartupAnimation then return end

    local ActiveModules = 0
    if WMConfig.ShowFPS then ActiveModules = ActiveModules + 1 end
    if WMConfig.ShowPing then ActiveModules = ActiveModules + 1 end
    if WMConfig.ShowHP then ActiveModules = ActiveModules + 1 end
    if WMConfig.ShowTime then ActiveModules = ActiveModules + 1 end
    if WMConfig.ShowJob then ActiveModules = ActiveModules + 1 end
    if WMConfig.ShowPlaytime then ActiveModules = ActiveModules + 1 end
    if WMConfig.ShowServer then ActiveModules = ActiveModules + 1 end
    if WMConfig.ShowCops then ActiveModules = ActiveModules + 1 end
    if WMConfig.ShowProfit then ActiveModules = ActiveModules + 1 end

    if WMConfig.AutoPosition and not Dragging then
        if ActiveModules > 3 or WMConfig.ShowVehicle then
            local TargetX = (Camera.ViewportSize.X / 2) - (MainFrame.Size.X.Offset / 2)
            MainFrame.Position = UDim2.new(0, TargetX, 0, 20)
        else
            MainFrame.Position = UDim2.new(0, 15, 0, 50)
        end
    elseif not Dragging then
        MainFrame.Position = UDim2.new(0, WMConfig.PosX, 0, WMConfig.PosY)
    end

    local IsLowHealth = false
    local CurrentHealth = 100
    pcall(function()
        local Humanoid = LocalPlayer.Character:FindFirstChild("Humanoid")
        if Humanoid then 
            CurrentHealth = math.floor(Humanoid.Health)
            if Humanoid.Health <= 35 and Humanoid.Health > 0 then IsLowHealth = true end
        end
    end)

    local BaseColor = Color3.fromRGB(WMConfig.AccentR, WMConfig.AccentG, WMConfig.AccentB)
    local HexAccent = string.format("#%02X%02X%02X", BaseColor.R*255, BaseColor.G*255, BaseColor.B*255)
    
    if WMConfig.RGBText then
        local RGB = Color3.fromHSV(tick() % 5 / 5, 1, 1)
        HexAccent = string.format("#%02X%02X%02X", RGB.R*255, RGB.G*255, RGB.B*255)
    end

    if WMConfig.HealthWarning and IsLowHealth and math.floor(tick() * 6) % 2 == 0 then
        HexAccent = "#ff0000"
        if WMConfig.Style == "Onetap" then TopLine.BackgroundColor3 = Color3.fromRGB(255,0,0) end
        if WMConfig.Style == "Neon" then MainStroke.Color = Color3.fromRGB(255,0,0) end
    else
        if WMConfig.RGBLine then
            local RGBLineColor = Color3.fromHSV(tick() % 5 / 5, 1, 1)
            if WMConfig.Style == "Onetap" then TopLine.BackgroundColor3 = RGBLineColor end
            if WMConfig.Style == "Neon" then MainStroke.Color = RGBLineColor end
        else
            if WMConfig.Style == "Onetap" then TopLine.BackgroundColor3 = BaseColor end
            if WMConfig.Style == "Neon" then MainStroke.Color = BaseColor end
        end
    end

    local Content = ""
    if WMConfig.UseIcons then Content = "👑 " else Content = "" end
    Content = Content .. string.format('<font color="%s">INFINITY</font> | ', HexAccent)

    if WMConfig.ShowFPS then 
        local FPSColor = RealFPS < 30 and "#f97316" or "#ffffff" 
        Content = Content .. string.format('%s<font color="%s">%d</font> | ', (WMConfig.UseIcons and "🚀 " or "FPS: "), FPSColor, RealFPS)
    end
    
    if WMConfig.ShowPing then
        local PingValue = 0
        pcall(function() PingValue = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue()) end)
        local PingColor = PingValue > 100 and "#ef4444" or "#ffffff"
        Content = Content .. string.format('%s<font color="%s">%dms</font> | ', (WMConfig.UseIcons and "📡 " or "Ping: "), PingColor, PingValue)
    end

    if WMConfig.ShowHP then Content = Content .. (WMConfig.UseIcons and "❤️ " or "HP: ") .. CurrentHealth .. " | " end
    if WMConfig.ShowTime then Content = Content .. (WMConfig.UseIcons and "⌚ " or "Time: ") .. os.date("%H:%M") .. " | " end
    if WMConfig.ShowPlaytime then 
        local PT = tick() - SessionStart
        Content = Content .. (WMConfig.UseIcons and "⏳ " or "Session: ") .. string.format("%02d:%02d", math.floor(PT/60), math.floor(PT%60)) .. " | " 
    end
    if WMConfig.ShowServer then Content = Content .. (WMConfig.UseIcons and "🌍 " or "Players: ") .. #Players:GetPlayers() .. " | " end
    
    if WMConfig.ShowCops then
        local CopCount = 0
        for _, Player in pairs(Players:GetPlayers()) do
            pcall(function()
                local JobStr = string.lower(Player.leaderstats.Job.Value)
                if JobStr:match("police") or JobStr:match("cop") then CopCount = CopCount + 1 end
            end)
        end
        Content = Content .. (WMConfig.UseIcons and "👮 " or "Cops: ") .. CopCount .. " | "
    end

    if WMConfig.ShowProfit and InitialMoneyCaptured then
        local CurrentProfit = GetCurrentMoney() - InitialMoney
        local ProfitStr = CurrentProfit >= 0 and ("+" .. CurrentProfit) or tostring(CurrentProfit)
        local ProfitColor = CurrentProfit >= 0 and "#22c55e" or "#ef4444"
        Content = Content .. string.format('%s<font color="%s">%s</font> | ', (WMConfig.UseIcons and "💸 " or "Profit: "), ProfitColor, ProfitStr)
    end

    if WMConfig.ShowJob then
        local CurrentJob, CurrentWanted = "Citizen", 0
        pcall(function()
            CurrentJob = LocalPlayer.leaderstats.Job.Value
            CurrentWanted = LocalPlayer.leaderstats.Wanted.Value
        end)
        Content = Content .. (WMConfig.UseIcons and "💼 " or "Job: ") .. CurrentJob .. " " .. string.rep("⭐", CurrentWanted) .. " | "
    end

    Content = Content:sub(1, -4)
    MainText.Text = Content
    MainFrame.Size = UDim2.new(0, MainText.TextBounds.X + 20, 0, 22)
    VehicleFrame.Size = UDim2.new(0, MainFrame.Size.X.Offset, 0, IsVehicleMenuOpen and 22 or 0)

    if WMConfig.ShowVehicle then
        local IsInVehicle = false
        local VehSpeed, VehFuel, VehHealth = 0, "100%", "100%"
        
        pcall(function()
            local Char = LocalPlayer.Character
            local Hum = Char and Char:FindFirstChild("Humanoid")
            local Root = Char and Char:FindFirstChild("HumanoidRootPart")
            
            if Hum and Root then
                VehSpeed = math.floor(Root.Velocity.Magnitude * 1.09)
                if Hum.SeatPart then
                    IsInVehicle = true
                elseif VehSpeed >= 20 and Hum:GetState() ~= Enum.HumanoidStateType.Freefall and Hum:GetState() ~= Enum.HumanoidStateType.Jumping then
                    IsInVehicle = true
                end

                if IsInVehicle and Hum.SeatPart then
                    local CarModel = Hum.SeatPart:FindFirstAncestorOfClass("Model")
                    if CarModel then
                        if CarModel:GetAttribute("Fuel") then VehFuel = math.floor(CarModel:GetAttribute("Fuel")) .. "%" end
                        if CarModel:GetAttribute("Health") then VehHealth = math.floor(CarModel:GetAttribute("Health")) .. "%" end
                    end
                end
            end
        end)

        if IsInVehicle and not IsVehicleMenuOpen then
            IsVehicleMenuOpen = true
            TweenService:Create(VehicleFrame, TweenInfo.new(0.3), {Size = UDim2.new(1, 0, 0, 22)}):Play()
            TweenService:Create(VehicleText, TweenInfo.new(0.3), {TextTransparency = 0}):Play()
        elseif not IsInVehicle and IsVehicleMenuOpen then
            IsVehicleMenuOpen = false
            TweenService:Create(VehicleFrame, TweenInfo.new(0.3), {Size = UDim2.new(1, 0, 0, 0)}):Play()
            TweenService:Create(VehicleText, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
        end

        if IsInVehicle then
            VehicleText.Text = string.format("KM/H: %d | Fuel: %s | Health: %s", VehSpeed, VehFuel, VehHealth)
        end
    end

    if WMConfig.Breathing and not IsLowHealth then
        local BreathCycle = (math.sin(tick() * 3) + 1) / 2
        MainStroke.Transparency = BreathCycle
        if WMConfig.Style == "Onetap" then TopLine.BackgroundTransparency = BreathCycle end
    end
end)

