            FXCache.ThermalBloom.Intensity = 1.5
            FXCache.ThermalBloom.Size = 24
            FXCache.ThermalBloom.Threshold = 0.8
        end
        -- Apply heat signatures to all players
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character then ApplyThermalToEntity(p.Character) end
        end
    else
        if ThermalActive then
            ThermalActive = false
            Lighting.Ambient = OriginalLightingAmbient or Color3.fromRGB(128, 128, 128)
            Lighting.OutdoorAmbient = OriginalLightingAmbient or Color3.fromRGB(128, 128, 128)
            
            FXCache.ThermalCC.Enabled = false
