-- 15.2 THE ABSOLUTE DEEP CLEAN UNLOAD SCRIPT
-- This is designed to track down every single modification made by the script across the entire Roblox engine and revert it.
local function PerformDeepClean()
    -- 1. Unload UI Menus
    pcall(function() Window:Destroy() end)
    
    -- 2. Destroy Watermark & Custom Guis
    pcall(function()
        local Core = (gethui and gethui()) or CoreGui
        if Core:FindFirstChild("InfinityPremiumWatermark") then Core.InfinityPremiumWatermark:Destroy() end
        if Core:FindFirstChild("InfinityESP") then Core.InfinityESP:Destroy() end
        if Core:FindFirstChild("InfinityWaypoints") then Core.InfinityWaypoints:Destroy() end
        if Core:FindFirstChild("InfCinematicBorders") then Core.InfCinematicBorders:Destroy() end
    end)
    
    -- 3. Cleanup Workspace Objects (Underglow, Waypoints, Effects)
    pcall(function()
        for _, obj in pairs(Workspace:GetChildren()) do
            if obj:IsA("Part") and obj.Name:match("WM_") then obj:Destroy() end
            if obj:IsA("Part") and obj.Transparency == 1 and obj:FindFirstChild("SurfaceLight") then obj:Destroy() end
        end
    end)
    
    -- 4. Revert Lighting Effects (Depth of Field, Blur, ColorCorrection, Thermal, Sky)
    pcall(function()
        local L = game:GetService("Lighting")
        local removeTargets = {"InfDoF", "InfColorCorrection", "InfAcid", "InfDrunk", "InfNightVision", "InfNoir", "InfThermalBase", "InfThermalBloom", "InfGlitch"}
        for _, name in pairs(removeTargets) do
            if L:FindFirstChild(name) then L[name]:Destroy() end
        end
        L.Ambient = Color3.fromRGB(128, 128, 128)
        L.OutdoorAmbient = Color3.fromRGB(128, 128, 128)
        L.Brightness = 1
        L.GlobalShadows = true
        L.FogEnd = 10000
    end)
    
    -- 5. Revert Audio Manipulations
    pcall(function()
        local S = game:GetService("SoundService")
        S.DistanceFactor = 3.33
        local removeAudios = {"InfEqualizer", "InfPitch", "InfEcho"}
        for _, name in pairs(removeAudios) do
            if S:FindFirstChild(name) then S[name]:Destroy() end
        end
        if CoreGui:FindFirstChild("Sound") then CoreGui.Sound:Destroy() end -- Hitmarker sound
    end)
    
    -- 6. Restore Player Properties (Movement, Camera, Freecam)
    pcall(function()
        local Char = LocalPlayer.Character
        if Char then
            local Hum = Char:FindFirstChild("Humanoid")
            if Hum then
                Hum.WalkSpeed = 16
                Hum.UseJumpPower = true
                Hum.JumpPower = 50
            end
            local Root = Char:FindFirstChild("HumanoidRootPart")
            if Root then Root.Anchored = false end
        end
        Camera.CameraType = Enum.CameraType.Custom
        Camera.FieldOfView = 70
        UserInputService.MouseBehavior = Enum.MouseBehavior.Default
    end)
    
    -- 7. Restore Hidden CoreGUIs
    pcall(function()
        game:GetService("StarterGui"):SetCoreGuiEnabled(Enum.CoreGuiType.All, true)
        if LocalPlayer.PlayerGui:FindFirstChild("MainGui") then
            LocalPlayer.PlayerGui.MainGui.Enabled = true
        end
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character and p.Character:FindFirstChild("Head") then
                for _, obj in pairs(p.Character.Head:GetChildren()) do
                    if obj:IsA("BillboardGui") then obj.Enabled = true end
                end
            end
        end
    end)
end

