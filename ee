local CHLines = {
    Top = Drawing.new("Line"), Bottom = Drawing.new("Line"),
    Left = Drawing.new("Line"), Right = Drawing.new("Line")
}
for _, line in pairs(CHLines) do line.Visible = false; line.ZIndex = 1000 end
local CHRotation = 0

RunService.RenderStepped:Connect(function(dt)
    if not CombatCfg.CrosshairEnabled then
        for _, line in pairs(CHLines) do line.Visible = false end
        return
    end

    if CombatCfg.CHHideScope then
        local Scoped = false
        pcall(function()
            local PGui = LocalPlayer:FindFirstChild("PlayerGui")
            if PGui then
                for _, element in pairs(PGui:GetChildren()) do
                    if element:FindFirstChild("5") and element:GetChildren()[1]:FindFirstChild("5").Image == "rbxassetid://285779644" then Scoped = true end
                end
            end
        end)
        if Scoped then
            for _, line in pairs(CHLines) do line.Visible = false end
            return
        end
    end

    local Viewport = Camera.ViewportSize
    local TargetPos = Vector2.new(Viewport.X / 2, (Viewport.Y / 2) - 18) -- Account for Roblox Topbar
    local BaseColor = Color3.fromRGB(CombatCfg.CHColorR, CombatCfg.CHColorG, CombatCfg.CHColorB)
    local ActiveGap = CombatCfg.CHGap

    if CombatCfg.CHDynamic then
        pcall(function()
            local Speed = LocalPlayer.Character.HumanoidRootPart.Velocity.Magnitude
            ActiveGap = ActiveGap + (Speed / 3.5)
        end)
    end

    local BaseAngle = CombatCfg.CHXShape and 45 or 0
    if CombatCfg.CHSpin then
        CHRotation = (CHRotation + (CombatCfg.CHSpinSpeed * dt)) % 360
    else
        CHRotation = 0
    end

    local Rad = math.rad(CHRotation + BaseAngle)
    local CosA, SinA = math.cos(Rad), math.sin(Rad)

    local function RotatePoint(ox, oy)
        return Vector2.new(TargetPos.X + (ox * CosA - oy * SinA), TargetPos.Y + (ox * SinA + oy * CosA))
    end

    CHLines.Top.From = RotatePoint(0, -ActiveGap)
    CHLines.Top.To = RotatePoint(0, -(ActiveGap + CombatCfg.CHLength))
    CHLines.Bottom.From = RotatePoint(0, ActiveGap)
    CHLines.Bottom.To = RotatePoint(0, ActiveGap + CombatCfg.CHLength)
    CHLines.Left.From = RotatePoint(-ActiveGap, 0)
    CHLines.Left.To = RotatePoint(-(ActiveGap + CombatCfg.CHLength), 0)
    CHLines.Right.From = RotatePoint(ActiveGap, 0)
    CHLines.Right.To = RotatePoint(ActiveGap + CombatCfg.CHLength, 0)

    for name, line in pairs(CHLines) do
        line.Color = BaseColor
        line.Thickness = CombatCfg.CHThickness
        line.Transparency = CombatCfg.CHAlpha
        if CombatCfg.CHTShape and not CombatCfg.CHXShape and name == "Top" then
            line.Visible = false
        else
            line.Visible = true
        end
    end
end)

