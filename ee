local function LoadMasterConfig()
    pcall(function()
        if isfile(ConfigFile) then
            local DecodedData = HttpService:JSONDecode(readfile(ConfigFile))
            for category, settings in pairs(DecodedData) do
                if MasterConfig[category] then
                    for key, value in pairs(settings) do
                        MasterConfig[category][key] = value
                    end
                end
            end
        end
    end)
end

