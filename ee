-- 12.2 THERMAL VISION ENGINE (Deep Workspace Manipulation)
local ThermalActive = false
local OriginalMaterials = {}
local OriginalColors = {}
local OriginalLightingAmbient

local function ApplyThermalToEntity(Character)
    pcall(function()
        for _, part in pairs(Character:GetDescendants()) do
            if part:IsA("BasePart") then
                if not OriginalMaterials[part] then OriginalMaterials[part] = part.Material end
                if not OriginalColors[part] then OriginalColors[part] = part.Color end
                part.Material = Enum.Material.Neon
                part.Color = Color3.fromRGB(FXCfg.ThermalEntityColorR, FXCfg.ThermalEntityColorG, FXCfg.ThermalEntityColorB)
            elseif part:IsA("Clothing") or part:IsA("Shirt") or part:IsA("Pants") or part:IsA("Decal") then
                -- Hide clothing to make the heat signature pure
                if not OriginalMaterials[part] then OriginalMaterials[part] = part.Transparency end
                part.Transparency = 1
            end
        end
    end)
end

local function RevertThermalOnEntity(Character)
    pcall(function()
        for _, part in pairs(Character:GetDescendants()) do
            if part:IsA("BasePart") then
                if OriginalMaterials[part] then part.Material = OriginalMaterials[part] end
                if OriginalColors[part] then part.Color = OriginalColors[part] end
            elseif part:IsA("Clothing") or part:IsA("Shirt") or part:IsA("Pants") or part:IsA("Decal") then
                if OriginalMaterials[part] then part.Transparency = OriginalMaterials[part] end
            end
        end
    end)
end

local function UpdateThermalVision()
    if FXCfg.ThermalVision then
        if not ThermalActive then
            ThermalActive = true
            OriginalLightingAmbient = Lighting.Ambient
            
            -- Setup Environment for Thermal (Cold background)
            Lighting.Ambient = Color3.fromRGB(10, 10, 50)
            Lighting.OutdoorAmbient = Color3.fromRGB(5, 5, 30)
            
