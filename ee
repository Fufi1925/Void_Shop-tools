local function ApplyWeaponSkin(Weapon, SkinName, Type)
    if not Weapon or SkinName == "Default" or not TexDB.Weapon[SkinName] then return end
    pcall(function()
        local Prim, Sec = nil, {}
        if Type == "Sniper" then
            Prim = Weapon:FindFirstChild("Green")
            table.insert(Sec, Weapon:FindFirstChild("Base"))
        elseif Type == "G36" then
            Prim = Weapon:FindFirstChild("Body")
            for _, n in ipairs({"Stock", "Scope", "FlashlightBody"}) do
                if Weapon:FindFirstChild(n) then table.insert(Sec, Weapon[n]) end
            end
        end
        if Prim then Prim.TextureID = TexDB.Weapon[SkinName].P end
        for _, s in ipairs(Sec) do s.TextureID = TexDB.Weapon[SkinName].S end
    end)
end

local function ApplyGearSkin(Gear, SkinName)
    if not Gear or SkinName == "Default" or not TexDB.Gear[SkinName] then return end
    pcall(function()
        local MP = Gear:FindFirstChild("MainPart")
        if MP then MP.TextureID = TexDB.Gear[SkinName] end
    end)
end

task.spawn(function()
    while task.wait(1) do
        if SkinCfg.SkinActive then
            local Targets = {LocalPlayer}
            if SkinCfg.ApplyToAll then Targets = Players:GetPlayers() end

            for _, P in pairs(Targets) do
                pcall(function()
                    local Char = P.Character
                    if Char then
                        ApplyWeaponSkin(Char:FindFirstChild("Sniper"), SkinCfg.SniperSkin, "Sniper")
                        ApplyWeaponSkin(Char:FindFirstChild("G36"), SkinCfg.G36Skin, "G36")
                        
                        local Acc = Char:FindFirstChild("PlayerAccessories")
                        if Acc then
                            ApplyGearSkin(Acc:FindFirstChild("Criminal Helmet"), SkinCfg.HelmetSkin)
                            ApplyGearSkin(Acc:FindFirstChild("Criminal Vest"), SkinCfg.VestSkin)
                        end
                    end
                end)
            end
        end
    end
end)

