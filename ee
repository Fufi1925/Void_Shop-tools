    if not OffscreenCache[ID] then
        local T = Drawing.new("Triangle")
        T.ZIndex = 500
        T.Filled = true
        OffscreenCache[ID] = T
    end
    return OffscreenCache[ID]
end

-- 9.3 RENDER ENGINE (Calculates Distances, Offscreen Math, and Bobbing)
local RenderWpConnection
local function StartWaypointEngine()
    if RenderWpConnection then RenderWpConnection:Disconnect(); RenderWpConnection = nil end
    if not WpCfg.Enabled then
        for ID, _ in pairs(WaypointCache) do ClearWaypointCache(ID) end
        return
    end

    RenderWpConnection = RunService.RenderStepped:Connect(function()
        pcall(function()
            local Root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            local CameraPos = Camera.CFrame.Position
            local Viewport = Camera.ViewportSize
            local CenterX, CenterY = Viewport.X / 2, Viewport.Y / 2
            
            -- Combine Core Locations and Custom Waypoints into one processing list
            local ActivePoints = {}
            for Name, Data in pairs(CoreLocations) do
                if Data.Active then table.insert(ActivePoints, {ID = "Core_"..Name, Name = Name, Pos = Data.Pos, Color = Data.Color}) end
            end
            for idx, Data in ipairs(WpCfg.CustomWaypoints) do
                table.insert(ActivePoints, {ID = "Cust_"..idx, Name = Data.Name, Pos = Vector3.new(Data.X, Data.Y, Data.Z), Color = Color3.fromRGB(Data.R, Data.G, Data.B)})
            end

            -- Clean up unused markers
            local ActiveIDs = {}
            for _, AP in ipairs(ActivePoints) do ActiveIDs[AP.ID] = true end
            for ID, _ in pairs(WaypointCache) do
                if not ActiveIDs[ID] then ClearWaypointCache(ID) end
            end

            for _, AP in ipairs(ActivePoints) do
                local Dist = Root and math.floor((Root.Position - AP.Pos).Magnitude) or 0
                local W2S, OnScreen = Camera:WorldToViewportPoint(AP.Pos)
                
                -- Dynamic Bobbing Math
                local OffsetY = 0
                if WpCfg.Bobbing then
                    OffsetY = math.sin(tick() * WpCfg.BobbingSpeed) * 3
                end
                
                local FinalWorldPos = AP.Pos + Vector3.new(0, OffsetY, 0)
                local W2S_Bobbed = Camera:WorldToViewportPoint(FinalWorldPos)

                -- 3D Billboard Logic
                local Marker = Create3DMarker(AP.ID, AP.Name, AP.Color)
                if OnScreen then
                    Marker.Enabled = true
                    Marker.Adornee = nil -- Use absolute positioning for smooth bobbing
                    -- Scale text based on distance (clamp between 8 and max config)
                    local Scale = math.clamp(1000 / Dist, 8, WpCfg.TextScale)
                    Marker.TextLabel.TextSize = Scale
                    Marker.TextLabel.Text = string.format("%s\n<font size='%d'>[%dm]</font>", AP.Name, Scale-2, Dist)
                    
                    -- Convert Viewport to UDim2 Position for ScreenGui bypass
                    -- Actually, since it's a Billboard, we can just use StudsOffsetWorldSpace
                    Marker.Adornee = Workspace.Terrain -- Bind to terrain, position manually
                    Marker.ExtentsOffsetWorldSpace = FinalWorldPos
                else
                    Marker.Enabled = false
                end

                -- Tracer Line Logic
                local Line = GetDrawingLine(AP.ID)
                if WpCfg.ShowLines and OnScreen and Root then
                    local RootW2S = Camera:WorldToViewportPoint(Root.Position)
                    Line.Visible = true
                    Line.From = Vector2.new(CenterX, Viewport.Y) -- Bottom center of screen
                    Line.To = Vector2.new(W2S_Bobbed.X, W2S_Bobbed.Y)
                    Line.Color = Color3.fromRGB(WpCfg.LineColorR, WpCfg.LineColorG, WpCfg.LineColorB)
                    Line.Thickness = WpCfg.LineThickness
                    Line.Transparency = WpCfg.LineAlpha
                else
                    Line.Visible = false
                end

                -- Offscreen Arrow Logic (Complex Math)
                local Tri = GetOffscreenTriangle(AP.ID)
                if WpCfg.ShowOffscreen and not OnScreen then
                    Tri.Visible = true
                    Tri.Color = AP.Color
                    
                    local RelPos = Camera.CFrame:PointToObjectSpace(AP.Pos)
                    local Angle = math.atan2(RelPos.X, -RelPos.Z)
                    
                    local Radius = WpCfg.OffscreenRadius
                    local ArrowX = CenterX + math.sin(Angle) * Radius
                    local ArrowY = CenterY - math.cos(Angle) * Radius
                    
                    -- Triangle Rotation Math
                    local Size = WpCfg.OffscreenSize
                    local Point1 = Vector2.new(ArrowX + math.sin(Angle) * Size, ArrowY - math.cos(Angle) * Size)
                    local Point2 = Vector2.new(ArrowX + math.sin(Angle + 2.35) * Size, ArrowY - math.cos(Angle + 2.35) * Size)
                    local Point3 = Vector2.new(ArrowX + math.sin(Angle - 2.35) * Size, ArrowY - math.cos(Angle - 2.35) * Size)
                    
                    Tri.PointA = Point1
                    Tri.PointB = Point2
                    Tri.PointC = Point3
                else
                    Tri.Visible = false
                end
            end
        end)
    end)
end

