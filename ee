-- 8.3 MOVEMENT SPOOFING & CFRAME WALK
local function HandleMovementLogic()
    if MovementConnection then MovementConnection:Disconnect(); MovementConnection = nil end
    MovementConnection = RunService.RenderStepped:Connect(function(deltaTime)
        pcall(function()
            local Character = LocalPlayer.Character
            if not Character then return end
            local Humanoid = Character:FindFirstChild("Humanoid")
            local RootPart = Character:FindFirstChild("HumanoidRootPart")
            if not Humanoid or not RootPart then return end

            -- CFrame Walk (Bypasses basic anti-cheats)
            if PlrCfg.WalkSpeedSpoof and PlrCfg.UseCFrameWalk and Humanoid.MoveDirection.Magnitude > 0 then
                local MoveDir = Humanoid.MoveDirection.Unit
                local SpeedDiff = PlrCfg.WalkSpeedValue - Humanoid.WalkSpeed
                if SpeedDiff > 0 then
                    RootPart.CFrame = RootPart.CFrame + (MoveDir * (SpeedDiff * deltaTime))
                end
            elseif PlrCfg.WalkSpeedSpoof and not PlrCfg.UseCFrameWalk then
                Humanoid.WalkSpeed = PlrCfg.WalkSpeedValue
            end

            if PlrCfg.JumpPowerSpoof then
                Humanoid.UseJumpPower = true
                Humanoid.JumpPower = PlrCfg.JumpPowerValue
            end

            if PlrCfg.SafeFall then
                local Velocity = RootPart.AssemblyLinearVelocity
                if Velocity.Y < -PlrCfg.MaxFallSpeed then
                    RootPart.AssemblyLinearVelocity = Vector3.new(Velocity.X, -PlrCfg.MaxFallSpeed, Velocity.Z)
                end
            end

            if PlrCfg.AutoSprint then
                -- EH Specific Sprint implementation (Simulating Shift press)
                -- If EH uses WalkSpeed for sprint, this overrides it smoothly
                if Humanoid.MoveDirection.Magnitude > 0 then
                    Humanoid.WalkSpeed = math.max(Humanoid.WalkSpeed, 25)
                end
            end

            if PlrCfg.BunnyHop and UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                if Humanoid:GetState() == Enum.HumanoidStateType.Running or Humanoid:GetState() == Enum.HumanoidStateType.RunningNoPhysics then
                    Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                end
            end
        end)
    end)
end

