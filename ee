-- 13.3 SERVER HOPPER ENGINE (HTTP API Integration)
local function ServerHop()
    WindUI:Notify({Title = "Server Hopper", Content = "Searching for a new safe server...", Duration = 5, Icon = "loader"})
    pcall(function()
        local PlaceID = game.PlaceId
        local JobID = game.JobId
        local TeleportService = game:GetService("TeleportService")
        
        -- Construct Roblox API URL for server list
        local Url = "https://games.roblox.com/v1/games/" .. PlaceID .. "/servers/Public?sortOrder=Asc&limit=100"
        local Success, Result = pcall(function() return HttpService:JSONDecode(game:HttpGet(Url)) end)
        
        if Success and Result and Result.data then
            local Servers = Result.data
            local SafeServers = {}
            
            -- Filter out full servers and current server
            for _, srv in ipairs(Servers) do
                if srv.playing < srv.maxPlayers and srv.id ~= JobID then
                    table.insert(SafeServers, srv.id)
                end
            end
            
            if #SafeServers > 0 then
                local RandomServer = SafeServers[math.random(1, #SafeServers)]
                WindUI:Notify({Title = "Teleporting", Content = "Connecting to new server...", Duration = 5, Icon = "zap"})
                TeleportService:TeleportToPlaceInstance(PlaceID, RandomServer, LocalPlayer)
            else
                WindUI:Notify({Title = "Error", Content = "No other suitable servers found.", Duration = 3, Icon = "triangle-alert"})
            end
        else
            WindUI:Notify({Title = "API Error", Content = "Could not fetch server list.", Duration = 3, Icon = "triangle-alert"})
        end
    end)
end

