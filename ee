local function GetCurrentMoney()
    local CurrentMoney = 0
    pcall(function()
        local Leaderstats = LocalPlayer:FindFirstChild("leaderstats")
        if Leaderstats then
            if Leaderstats:FindFirstChild("Cash") then
                CurrentMoney = Leaderstats.Cash.Value
            elseif Leaderstats:FindFirstChild("Money") then
                CurrentMoney = Leaderstats.Money.Value
            end
        end
    end)
    return CurrentMoney
end

