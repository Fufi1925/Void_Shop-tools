autoTab:Button({
    Title = "Hupe testen",
    Callback = function()
        for _, car in ipairs(autoGetTargets()) do
            local sounds = autoFindHornSounds(car)

            if #sounds > 0 then
                sounds[1]:Play()
                return
            end

            local main = autoGetMainPart(car)
            if main and autoHornId ~= "" then
                local s = Instance.new("Sound")
                s.SoundId = autoHornId
                s.Volume = autoHornVolume
                s.PlaybackSpeed = autoHornPitch
                s.Parent = main
                s:Play()

                game:GetService("Debris"):AddItem(s, 5)
                return
            end
        end
    end
})

