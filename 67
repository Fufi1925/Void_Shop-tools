-- === RENDER LOOP ===
local crosshairConnection = RunService.RenderStepped:Connect(function(dt)
    -- Originales Fadenkreuz ausblenden
    pcall(function()
        local plrGui = localPlayer:FindFirstChild("PlayerGui")
        if plrGui then
            for _, gui in pairs(plrGui:GetChildren()) do
                local first = gui:GetChildren()[1]
                if first then
                    local target = first:FindFirstChild("5")
                    if target and target:IsA("ImageLabel") and target.Image == "rbxassetid://285779644" then
                        first.Visible = not chHideOriginal
                    end
                end
            end
        end
    end)

    -- Wenn deaktiviert, alles unsichtbar machen
    if not chEnabled then
        for _, line in pairs(chLines) do line.Visible = false end
        chCenterDot.Visible = false
        return
    end

    -- Position berechnen (Mitte oder Maus)
    local targetPos
    if chCenterLocked then
        -- Bildschirmmitte
        local viewport = Camera.ViewportSize
        targetPos = Vector2.new(viewport.X / 2, (viewport.Y / 2) + 18) -- +18 gleicht die Roblox Topbar aus
    else
        -- Mausposition
        targetPos = UserInputService:GetMouseLocation()
    end

    -- Farbe berechnen
    local activeColor = chRGB and Color3.fromHSV(tick() % 5 / 5, 1, 1) or chColor

    -- Rotation berechnen
    if chSpin then
        currentRotation = currentRotation + (chSpinSpeed * dt)
        if currentRotation >= 360 then currentRotation = currentRotation - 360 end
    else
        currentRotation = 0
    end

    local rad = math.rad(currentRotation)
    local cosA = math.cos(rad)
    local sinA = math.sin(rad)

    local function rotatePoint(offsetX, offsetY)
        return Vector2.new(
            targetPos.X + (offsetX * cosA - offsetY * sinA),
            targetPos.Y + (offsetX * sinA + offsetY * cosA)
        )
    end

    -- Linien Positionen anwenden
    chLines.Top.From = rotatePoint(0, -chGap)
    chLines.Top.To = rotatePoint(0, -(chGap + chLength))
    
    chLines.Bottom.From = rotatePoint(0, chGap)
    chLines.Bottom.To = rotatePoint(0, chGap + chLength)
    
    chLines.Left.From = rotatePoint(-chGap, 0)
    chLines.Left.To = rotatePoint(-(chGap + chLength), 0)
    
    chLines.Right.From = rotatePoint(chGap, 0)
    chLines.Right.To = rotatePoint(chGap + chLength, 0)

    -- Eigenschaften anwenden und sichtbar machen
    for _, line in pairs(chLines) do
        line.Color = activeColor
        line.Thickness = chThickness
        line.Visible = true
    end

    -- Punkt in der Mitte
    if chDot then
        chCenterDot.Position = targetPos
        chCenterDot.Radius = chThickness
        chCenterDot.Color = activeColor
        chCenterDot.Visible = true
    else
        chCenterDot.Visible = false
    end
end)

-- === CLEANUP BEIM SCHLIESSEN DES SCRIPTS ===
Window:OnDestroy(function()
    if crosshairConnection then crosshairConnection:Disconnect() end
    for _, line in pairs(chLines) do line:Remove() end
    if chCenterDot then chCenterDot:Remove() end
end)

