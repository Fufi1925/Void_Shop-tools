settingsTab:Button({
    Title = '<font color="#ff0000">🔴 KILL SCRIPT 🔴</font>',
    Desc = "Löscht das UI und setzt alles im Spiel auf Standard zurück",
    Callback = function()
        -- Himmel & Lighting
        skystate = false
        if stdsky then
            for prop, value in pairs(stdsky) do
                skyInstance[prop] = value
            end
        end
        if skyconnection then skyconnection:Disconnect() end
        if fullbrightConnection then fullbrightConnection:Disconnect() end
        if timeConnection then timeConnection:Disconnect() end
        if originalLighting then
            Lighting.Brightness = originalLighting.Brightness
            Lighting.GlobalShadows = originalLighting.GlobalShadows
            Lighting.OutdoorAmbient = originalLighting.OutdoorAmbient
        end

        -- Underglow
        ENABLED = false
        for car, data in pairs(underglows) do
            if data.part then data.part:Destroy() end
        end
        underglows = {}

        -- Skins & Gear
        skinactive = false
        for _, player in pairs(Players:GetPlayers()) do
            if player.Character then
                local pSniper = player.Character:FindFirstChild("Sniper")
                local pG36 = player.Character:FindFirstChild("G36")
                
                if pSniper and pSniper:FindFirstChild("Green") then pSniper.Green.TextureID = "" end
                if pSniper and pSniper:FindFirstChild("Base") then pSniper.Base.TextureID = "" end
                if pG36 and pG36:FindFirstChild("Body") then pG36.Body.TextureID = "" end
                if pG36 and pG36:FindFirstChild("Stock") then pG36.Stock.TextureID = "" end
                if pG36 and pG36:FindFirstChild("Scope") then pG36.Scope.TextureID = "" end
                if pG36 and pG36:FindFirstChild("FlashlightBody") then pG36.FlashlightBody.TextureID = "" end
                
                local acc = player.Character:FindFirstChild("PlayerAccessories")
                if acc then
                    local helm = acc:FindFirstChild("Criminal Helmet")
                    if helm and helm:FindFirstChild("MainPart") then helm.MainPart.TextureID = "rbxassetid://17712965665" end
                    local vest = acc:FindFirstChild("Criminal Vest")
                    if vest and vest:FindFirstChild("MainPart") then vest.MainPart.TextureID = "rbxassetid://17712967030" end
                end
            end
        end

        -- Fadenkreuz
        usecrosshair = false
        if p1 and p2 and p3 and p4 then
            p1.Size = UDim2.new(0, 2, 0, 15)
            p2.Size = UDim2.new(0, 15, 0, 2)
            p3.Size = UDim2.new(0, 2, 0, 15)
            p4.Size = UDim2.new(0, 15, 0, 2)
            p1.BackgroundColor3 = Color3.new(1,1,1)
            p2.BackgroundColor3 = Color3.new(1,1,1)
            p3.BackgroundColor3 = Color3.new(1,1,1)
            p4.BackgroundColor3 = Color3.new(1,1,1)
        end

        -- Sniper Misc Connections
        if noScopeConn then noScopeConn:Disconnect() end
        if cooldownConn then cooldownConn:Disconnect() end

        -- Script UI zerstören
        pcall(function() Window:Destroy() end)
    end
})
