local autoApplyAll = false
local autoPaintEnabled = false
local autoRainbowPaint = false
local autoPaintColor = Color3.fromRGB(255, 0, 0)
local autoMaterial = Enum.Material.SmoothPlastic

local autoUnderglowEnabled = false
local autoUnderglowRainbow = false
local autoUnderglowPulse = false
local autoUnderglowColor = Color3.fromRGB(255, 0, 0)
local autoUnderglowRange = 10
local autoUnderglowBrightness = 4

local autoLightsEnabled = false
local autoLightsColor = Color3.fromRGB(255, 255, 255)
local autoLightsBrightness = 3

local autoHornEnabled = false
local autoHornId = ""
local autoHornVolume = 1
local autoHornPitch = 1

local autoTrailEnabled = false
local autoTrailColor = Color3.fromRGB(255, 0, 0)
local autoTrailLifetime = 0.35

local autoSavedParts = {}
local autoSavedLights = {}
local autoSavedSounds = {}

local autoUnderglows = {}
local autoTrails = {}

local autoRainbowHue = 0

local function autoVehiclesFolder()
    return workspace:FindFirstChild("Vehicles")
end

local function autoIsLocalCar(car)
    local plr = Players.LocalPlayer
    if not plr then return false end

    if car.Name:lower():find(plr.Name:lower()) then
        return true
    end

    local owner = car:FindFirstChild("Owner")
    if owner and owner.Value == plr then
        return true
    end

    return false
end

local function autoGetTargets()
    local vehicles = autoVehiclesFolder()
    local targets = {}

    if not vehicles then
        return targets
    end

    for _, car in ipairs(vehicles:GetChildren()) do
        if autoApplyAll or autoIsLocalCar(car) then
            table.insert(targets, car)
        end
    end

    return targets
end

local function autoGetMainPart(car)
    local body = car:FindFirstChild("Body")

    if body then
        local main = body:FindFirstChild("Body")
        if main and main:IsA("BasePart") then
            return main
        end
    end

    if car.PrimaryPart and car.PrimaryPart:IsA("BasePart") then
        return car.PrimaryPart
    end

    for _, obj in ipairs(car:GetDescendants()) do
        if obj:IsA("BasePart") then
            return obj
        end
    end

    return nil
end

local function autoSavePart(part)
    if autoSavedParts[part] then return end

    autoSavedParts[part] = {
        Color = part.Color,
        Material = part.Material,
        Reflectance = part.Reflectance,
    }
end

local function autoSaveLight(light)
    if autoSavedLights[light] then return end

    autoSavedLights[light] = {
        Color = light.Color,
        Brightness = light.Brightness,
        Enabled = light.Enabled,
    }
end

local function autoSaveSound(sound)
    if autoSavedSounds[sound] then return end

    autoSavedSounds[sound] = {
        SoundId = sound.SoundId,
        Volume = sound.Volume,
        PlaybackSpeed = sound.PlaybackSpeed,
    }
end

local function autoIsPaintPart(part)
    local n = part.Name:lower()

    if n:find("wheel") then return false end
    if n:find("tire") then return false end
    if n:find("tyre") then return false end
    if n:find("glass") then return false end
    if n:find("window") then return false end
    if n:find("light") then return false end

    return true
end

local function autoApplyPaint(car, color)
    for _, obj in ipairs(car:GetDescendants()) do
        if obj:IsA("BasePart") and autoIsPaintPart(obj) then
            autoSavePart(obj)

            obj.Color = color
            obj.Material = autoMaterial
            obj.Reflectance = 0
        end
    end
end

local function autoApplyLights(car)
    for _, obj in ipairs(car:GetDescendants()) do
        if obj:IsA("PointLight") or obj:IsA("SpotLight") or obj:IsA("SurfaceLight") then
            autoSaveLight(obj)

            obj.Enabled = autoLightsEnabled
            obj.Color = autoLightsColor
            obj.Brightness = autoLightsBrightness
        end
    end
end

local function autoFindHornSounds(car)
    local list = {}

    for _, obj in ipairs(car:GetDescendants()) do
        if obj:IsA("Sound") then
            local n = obj.Name:lower()

            if n:find("horn") or n:find("honk") or n:find("hupe") or n:find("beep") then
                table.insert(list, obj)
            end
        end
    end

    return list
end

local function autoApplyHorn(car)
    local sounds = autoFindHornSounds(car)

    for _, sound in ipairs(sounds) do
        autoSaveSound(sound)

        if autoHornEnabled and autoHornId ~= "" then
            sound.SoundId = autoHornId
            sound.Volume = autoHornVolume
            sound.PlaybackSpeed = autoHornPitch
        else
            local old = autoSavedSounds[sound]
            if old then
                sound.SoundId = old.SoundId
                sound.Volume = old.Volume
                sound.PlaybackSpeed = old.PlaybackSpeed
            end
        end
    end
end

local function autoRemoveUnderglow(car)
    local data = autoUnderglows[car]

    if data then
        if data.Part then
            data.Part:Destroy()
        end

        autoUnderglows[car] = nil
    end
end

local function autoCreateUnderglow(car)
    if autoUnderglows[car] then return end

    local main = autoGetMainPart(car)
    if not main then return end

    local part = Instance.new("Part")
    part.Name = "INFINITYxEH_Auto_Underglow"
    part.Size = Vector3.new(5, 0.05, 12)
    part.Anchored = true
    part.CanCollide = false
    part.CanTouch = false
    part.CanQuery = false
    part.Transparency = 1
    part.Parent = workspace

    local light = Instance.new("SurfaceLight")
    light.Face = Enum.NormalId.Bottom
    light.Angle = 180
    light.Range = autoUnderglowRange
    light.Brightness = autoUnderglowBrightness
    light.Color = autoUnderglowColor
    light.Parent = part

    autoUnderglows[car] = {
        Part = part,
        Light = light,
        Main = main,
    }
end

local function autoRemoveTrail(car)
    local data = autoTrails[car]

    if data then
        if data.Trail then data.Trail:Destroy() end
        if data.A0 then data.A0:Destroy() end
        if data.A1 then data.A1:Destroy() end

        autoTrails[car] = nil
    end
end

local function autoCreateTrail(car)
    if autoTrails[car] then return end

    local main = autoGetMainPart(car)
    if not main then return end

    local a0 = Instance.new("Attachment")
    a0.Name = "INFINITYxEH_Trail_A0"
    a0.Position = Vector3.new(-2, -1, 3)
    a0.Parent = main

    local a1 = Instance.new("Attachment")
    a1.Name = "INFINITYxEH_Trail_A1"
    a1.Position = Vector3.new(2, -1, 3)
    a1.Parent = main

    local trail = Instance.new("Trail")
    trail.Name = "INFINITYxEH_Auto_Trail"
    trail.Attachment0 = a0
    trail.Attachment1 = a1
    trail.FaceCamera = true
    trail.Lifetime = autoTrailLifetime
    trail.LightEmission = 1
    trail.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.15),
        NumberSequenceKeypoint.new(1, 1),
    })
    trail.WidthScale = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 1),
        NumberSequenceKeypoint.new(1, 0),
    })
    trail.Color = ColorSequence.new(autoTrailColor)
    trail.Parent = main

    autoTrails[car] = {
        A0 = a0,
        A1 = a1,
        Trail = trail,
    }
end

local function autoApplyAll()
    local color = autoPaintColor

    if autoRainbowPaint then
        color = Color3.fromHSV(autoRainbowHue, 1, 1)
    end

    for _, car in ipairs(autoGetTargets()) do
        if autoPaintEnabled then
            autoApplyPaint(car, color)
        end

        autoApplyLights(car)
        autoApplyHorn(car)

        if autoUnderglowEnabled then
            autoCreateUnderglow(car)
        else
            autoRemoveUnderglow(car)
        end

        if autoTrailEnabled then
            autoCreateTrail(car)
        else
            autoRemoveTrail(car)
        end
    end
end

local function autoResetAll()
    for part, data in pairs(autoSavedParts) do
        if part and part.Parent then
            pcall(function()
                part.Color = data.Color
                part.Material = data.Material
                part.Reflectance = data.Reflectance
            end)
        end
    end

    for light, data in pairs(autoSavedLights) do
        if light and light.Parent then
            pcall(function()
                light.Color = data.Color
                light.Brightness = data.Brightness
                light.Enabled = data.Enabled
            end)
        end
    end

    for sound, data in pairs(autoSavedSounds) do
        if sound and sound.Parent then
            pcall(function()
                sound.SoundId = data.SoundId
                sound.Volume = data.Volume
                sound.PlaybackSpeed = data.PlaybackSpeed
            end)
        end
    end

    for car, _ in pairs(autoUnderglows) do
        autoRemoveUnderglow(car)
    end

    for car, _ in pairs(autoTrails) do
        autoRemoveTrail(car)
    end

    autoSavedParts = {}
    autoSavedLights = {}
    autoSavedSounds = {}
end

local autoRenderConn
autoRenderConn = RunService.RenderStepped:Connect(function(dt)
    autoRainbowHue = (autoRainbowHue + dt * 0.15) % 1

    local glowColor = autoUnderglowColor
    if autoUnderglowRainbow then
        glowColor = Color3.fromHSV(autoRainbowHue, 1, 1)
    end

    for car, data in pairs(autoUnderglows) do
        if not car or not car.Parent then
            autoRemoveUnderglow(car)
        elseif data.Main and data.Main.Parent and data.Part and data.Light then
            data.Part.CFrame = data.Main.CFrame * CFrame.new(0, -(data.Main.Size.Y / 2) - 0.45, 0)

            data.Light.Color = glowColor
            data.Light.Range = autoUnderglowRange

            if autoUnderglowPulse then
                data.Light.Brightness = autoUnderglowBrightness + math.sin(tick() * 5) * 1.5
            else
                data.Light.Brightness = autoUnderglowBrightness
            end
        end
    end

    for car, data in pairs(autoTrails) do
        if not car or not car.Parent then
            autoRemoveTrail(car)
        elseif data.Trail then
            data.Trail.Color = ColorSequence.new(autoTrailColor)
            data.Trail.Lifetime = autoTrailLifetime
        end
    end

    if autoPaintEnabled and autoRainbowPaint then
        autoApplyAll()
    end
end)

